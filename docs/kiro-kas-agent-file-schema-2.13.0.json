{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dwalleck/cyril/docs/kiro-kas-agent-file-schema-2.13.0.json",
  "title": "Kiro KAS (v3) agent file — JSON format",
  "$comment": "Reconstructed 2026-07-17 from the @kiro/agent (KAS 0.18.2) bundle shipped inside kiro-cli 2.13.0 (src/services/custom-agents/types.ts: CustomAgentFileFrontMatterSchema / JsonAgentFileSchema). NOT an official Kiro artifact. Runtime parsing is TOLERANT: zod z.object without .strict() silently strips unknown keys, so additionalProperties is intentionally left permissive here to mirror runtime; set \"additionalProperties\": false locally for typo-linting. v2-format marker fields the KAS loader checks for (CLI_ONLY_FIELDS): allowedTools, toolsSettings; KAS_MARKER_FIELDS: permissions. The v2 (Rust) engine agent schema is a DIFFERENT format (see docs/kiro-agent-schema-2.1.1.json) and, unlike this one, rejects unknown fields.",
  "description": "A JSON agent file (`.kiro/agents/*.json`) for the KAS (v3) engine.",
  "$ref": "#/$defs/JsonAgentFile",
  "$defs": {
    "McpServerWireRecord": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "AgentResource": {
      "anyOf": [
        {
          "type": "string",
          "description": "Context-file (`file://`) or skill (`skill://`) URI."
        },
        {
          "$ref": "#/$defs/KnowledgeBaseResource"
        }
      ]
    },
    "KnowledgeBaseResource": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "knowledgeBase"
        },
        "source": {
          "type": "string",
          "pattern": "^file:\\/\\/.*\\S",
          "description": "file:// URI with a non-empty path."
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "indexType": {
          "type": "string",
          "enum": [
            "fast",
            "best"
          ]
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "autoUpdate": {
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "source"
      ]
    },
    "PermissionsPolicy": {
      "type": "object",
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "capability": {
                "type": "string"
              },
              "match": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "exclude": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "effect": {
                "type": "string",
                "enum": [
                  "allow",
                  "deny",
                  "ask"
                ]
              }
            },
            "required": [
              "capability",
              "effect"
            ]
          }
        },
        "policies": {
          "description": "References to named policy bundles, expanded inline into scoped rules.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "rules"
      ]
    },
    "HookAction": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "command"
            },
            "command": {
              "type": "string",
              "minLength": 1,
              "description": "Shell command to run."
            }
          },
          "required": [
            "type",
            "command"
          ],
          "description": "Run a shell command."
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "agent"
            },
            "prompt": {
              "type": "string",
              "minLength": 1,
              "description": "Prompt injected for the agent to act on."
            }
          },
          "required": [
            "type",
            "prompt"
          ],
          "description": "Prompt the agent."
        }
      ]
    },
    "HookConfirm": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "run": {
                "type": "boolean"
              },
              "continueReason": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "label",
              "run"
            ]
          }
        }
      },
      "required": [
        "question",
        "options"
      ]
    },
    "HookDocument": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "minLength": 1,
          "description": "Hook trigger. Known triggers in KAS 0.18.2: preToolUse, postToolUse, promptSubmit, agentStop, preTaskExecution, postTaskExecution, sessionStart."
        },
        "matcher": {
          "type": "string"
        },
        "action": {
          "$ref": "#/$defs/HookAction"
        },
        "timeout": {
          "description": "Timeout in seconds (>= 0).",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "enabled": {
          "type": "boolean"
        },
        "confirm": {
          "$ref": "#/$defs/HookConfirm"
        }
      },
      "required": [
        "name",
        "trigger",
        "action"
      ]
    },
    "JsonAgentFile": {
      "type": "object",
      "properties": {
        "name": {
          "description": "Explicit agent name that overrides filename-based ID.",
          "type": "string",
          "minLength": 1
        },
        "description": {
          "description": "Human-readable description (defaults to empty string).",
          "type": "string"
        },
        "excludedTools": {
          "description": "Tools to exclude (applied after allowedTools matching).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model": {
          "description": "Model override.",
          "type": "string"
        },
        "includeMcpJson": {
          "default": false,
          "description": "Whether to automatically include MCP tools in the agent's available tools. When true, all MCP tools are included. When false (default), MCP tools are only included if explicitly matched by `tools` patterns.",
          "type": "boolean"
        },
        "includePowers": {
          "default": false,
          "description": "Whether to automatically include Powers tools in the agent's available tools. When true, the kiroPowers tool is included. When false (default), Powers tools are only included if explicitly matched by `tools` patterns.",
          "type": "boolean"
        },
        "mcpServers": {
          "description": "MCP servers to initialize for this agent, keyed by server name. Runtime is tolerant: a non-map value falls back to empty; entries are kept raw and classified per-entry later, so a malformed entry surfaces as a failed server rather than dropping the profile.",
          "$ref": "#/$defs/McpServerWireRecord"
        },
        "resources": {
          "description": "Context-file (`file://`), skill (`skill://`), and knowledge-base resources.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/AgentResource"
          }
        },
        "permissions": {
          "description": "Policy rules that scope down what this agent can do.",
          "$ref": "#/$defs/PermissionsPolicy"
        },
        "welcomeMessage": {
          "description": "Message displayed when switching to this agent.",
          "type": "string"
        },
        "dispatchKind": {
          "type": "string",
          "enum": [
            "sub-agent",
            "custom-agent",
            "spec"
          ],
          "description": "Controls which dispatch adapter handles this agent's execution."
        },
        "hooks": {
          "description": "Hooks embedded inline in the agent profile, scoped to the active agent.",
          "type": "array",
          "items": {
            "description": "A hook embedded inline in the agent profile, scoped to the active agent.",
            "$ref": "#/$defs/HookDocument"
          }
        },
        "prompt": {
          "description": "Prompt content (inline string or file:// URI, defaults to empty string).",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "tools": {
          "description": "Array of tool IDs or \"*\" for all tools.",
          "anyOf": [
            {
              "type": "string",
              "const": "*"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      }
    }
  }
}
