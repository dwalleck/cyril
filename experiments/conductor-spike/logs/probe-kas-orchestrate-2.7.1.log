                    "MAX",
                    "MIN",
                    "SUM",
                    "Average",
                    "Sum",
                    "Maximum",
                    "Minimum",
                    "SampleCount"
                  ],
                  "title": "Statistic",
                  "type": "string"
                }
              },
              "required": [
                "namespace",
                "metric_name"
              ],
              "$defs": {
                "Dimension": {
                  "description": "Represents a CloudWatch metric dimension for input parameters.",
                  "properties": {
                    "name": {
                      "description": "The name of the dimension",
                      "title": "Name",
