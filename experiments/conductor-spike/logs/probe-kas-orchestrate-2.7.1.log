                      "type": "array"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null,
                  "description": "Filter results by AWS product/service (e.g., [\"Amazon Simple Storage Service\"])",
                  "title": "Product Types"
                },
                "guide_types": {
                  "anyOf": [
                    {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null,
                  "description": "Filter results by guide type (e.g., [\"User Guide\", \"API Reference\", \"Developer Guide\"])",
                  "title": "Guide Types"
