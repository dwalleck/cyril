                  "title": "Statistic",
                  "type": "string"
                },
                "target_datapoints": {
                  "default": 60,
                  "description": "Target number of data points to return (default: 60). Controls the granularity of the returned data.",
                  "title": "Target Datapoints",
                  "type": "integer"
                },
                "group_by_dimension": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
